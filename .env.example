# ── Haldia Cloud Kitchen — Frontend environment variables ───────────────────
# Copy to ".env" for local dev, or set in your host (Vercel) project settings.
#
# Base URL of the deployed backend. NO trailing slash, NO "/api" suffix.
# The code appends "/api" for REST calls and uses the base URL for sockets/images.
VITE_API_URL=https://your-backend.onrender.com
